{
  "name": "herobrine-bot",
  "version": "0.2.0",
  "description": "A Discord bot that helps you in your Forever World :)",
  "main": "dist/index.js",
  "scripts": {
    "build":    "tsc",
    "dev":      "NODE_ENV=development tsx watch src/index.ts",
    "start":    "NODE_ENV=production node dist/index.js",

    "test":     "node --test",

    "register:dev":   "NODE_ENV=development tsx src/app/discord/register-commands.ts",
    "register:prod":  "NODE_ENV=production tsx src/app/discord/register-commands.ts",

    "migrate:dev":    "NODE_ENV=development tsx src/infrastructure/database/postgres/migrate.ts",
    "migrate:prod":   "NODE_ENV=production tsx src/infrastructure/database/postgres/migrate.ts",

    "tmp":      "NODE_ENV=development tsx tmp/tmp.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/educcamara/herobrine_bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/educcamara/herobrine_bot/issues"
  },
  "homepage": "https://github.com/educcamara/herobrine_bot#readme",
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.11",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "tsx": "^4.21.0",
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "@types/pg": "^8.16.0",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
